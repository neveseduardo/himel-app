{
  "enabled": true,
  "name": "PHP Format Check",
  "description": "Runs Laravel Pint code formatter on dirty PHP files after any PHP file is edited. Ensures consistent code style across the project.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.php"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "vendor/bin/pint --dirty --format agent",
    "timeout": 60
  }
}