{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"jsx": "preserve",
		"jsxImportSource": "vue",
		"useDefineForClassFields": true,
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"resources/js/*"
			],
			"@/lib/*": [
				"resources/js/domain/Shared/lib/*"
			],
			"@/lib": [
				"resources/js/domain/Shared/lib"
			],
			"@/composables/*": [
				"resources/js/domain/Shared/composables/*"
			],
			"@/types/*": [
				"resources/js/domain/Shared/types/*"
			],
			"@/types": [
				"resources/js/domain/Shared/types/index.ts"
			]
		},
		"types": [
			"vite/client",
			"unplugin-auto-import/types"
		],
		"resolveJsonModule": true,
		"allowJs": true,
		"strict": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"noEmit": true,
		"ignoreDeprecations": "5.0"
	},
	"include": [
		"resources/**/*.ts",
		"resources/**/*.tsx",
		"resources/**/*.vue",
		"resources/**/*.d.ts",
		"resources/js/domain/Shared/types/imports.d.ts",
		"auto-imports.d.ts",
		"components.d.ts"
	]
}